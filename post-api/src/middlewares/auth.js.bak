const jwt = require('jsonwebtoken');
require('dotenv').config();
const securityLevel = parseInt(process.env.SECURITY_LEVEL || '1');

module.exports = (req, res, next) => {
  const authHeader = req.headers.authorization;
  let token = null;
  if (authHeader) {
    token = authHeader.split(' ')[1];
  }

  // Se tem token, decodifica (independente do nível)
  if (token) {
    try {
      const decoded = jwt.verify(token, process.env.JWT_SECRET);
      req.user = {
        id: decoded.id,
        role: decoded.role,
        departmentId: decoded.departmentId
      };
      console.log(`[AUTH] Token OK: id=${req.user.id}, dept=${req.user.departmentId}, role=${req.user.role}`);
      return next();
    } catch (err) {
      if (securityLevel !== 1) {
        return res.status(401).json({ error: 'Token inválido' });
      }
      // fallback para nível 1
    }
  }

  // Nível 1: simula usuário (pega departmentId da query/body ou padrão)
  if (securityLevel === 1) {
    const departmentId = parseInt(req.body.departmentId || req.query.departmentId || 1);
    const userId = parseInt(req.body.userId || req.query.userId || 1);
    const role = req.body.role || 'USER';
    req.user = { id: userId, role, departmentId };
    console.log(`[AUTH] Nível 1 simulado: id=${userId}, dept=${departmentId}, role=${role}`);
    return next();
  }

  return res.status(401).json({ error: 'Token não fornecido' });
};